# ============================================================
#  Quote of the Day – .gitignore
# ============================================================

# ── Secrets & credentials ────────────────────────────────
config/db.php
.env
.env.*
!.env.example

# ── OS files ─────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────
*.log
logs/
error_log
php_errors.log

# ── PHP / Composer ────────────────────────────────────────
vendor/
composer.lock

# ── IDE & editor ─────────────────────────────────────────
.vscode/sftp.json
.idea/
*.swp
*.swo
*~

# ── Uploads / user content ───────────────────────────────
uploads/

# ── Temporary files ───────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.cache
